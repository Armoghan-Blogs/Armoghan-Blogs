{
  "printWidth": 80,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "useTabs": false,
  "htmlWhitespaceSensitivity": "css",
  "vueIndentScriptAndStyle": true,
  "embeddedLanguageFormatting": "auto",
  "proseWrap": "preserve",
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "printWidth": 100,
        "singleQuote": false,
        "bracketSpacing": false,
        "jsxBracketSameLine": true,
        "htmlWhitespaceSensitivity": "ignore",
        "embeddedLanguageFormatting": "off",
        "tabWidth": 4
      }
    },
    {
      "files": "*.md",
      "options": {
        "printWidth": 80,
        "singleQuote": false,
        "bracketSpacing": true,
        "jsxBracketSameLine": false,
        "htmlWhitespaceSensitivity": "ignore",
        "embeddedLanguageFormatting": "auto",
        "tabWidth": 2
      }
    },
    {
      "files": "*.css",
      "options": {
        "printWidth": 80,
        "singleQuote": false,
        "bracketSpacing": false,
        "jsxBracketSameLine": false,
        "htmlWhitespaceSensitivity": "ignore",
        "embeddedLanguageFormatting": "auto",
        "tabWidth": 2
      }
    },
    {
      "files": "*.js",
      "options": {
        "printWidth": 80,
        "singleQuote": true,
        "bracketSpacing": true,
        "jsxBracketSameLine": false,
        "htmlWhitespaceSensitivity": "ignore",
        "embeddedLanguageFormatting": "auto",
        "tabWidth": 2
      }
    }
  ]
}
