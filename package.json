{
  "name": "armoghan-blogs",
  "version": "1.0.0",
  "description": "My Personal Blogs Website built using Hugo and Decap-CMS",
  "main": "index.js",
  "scripts": {
    "stylelint": "stylelint '**/*.css'",
    "stylelint:fix": "stylelint '**/*.css' --fix",
    "format": "npm run prettier",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "eslint:fix": "eslint . --fix",
    "htmlhint": "htmlhint '**/*.html'",
    "markdownlint": "markdownlint '**/*.md'",
    "lint": "npm run eslint:fix && npm run stylelint:fix && npm run htmlhint && npm run markdownlint"
  },
  "keywords": [
    "hugo",
    "hugo-theme",
    "tailwind",
    "dark-mode",
    "static-site",
    "content-management",
    "decap-cms",
    "decap-cms-app",
    "netlify",
    "blogs",
    "web-development",
    "responsive-design",
    "frontend",
    "site-generator",
    "modern-web",
    "opensource",
    "website",
    "personal-blog",
    "armoghan-blogs",
    "armoghan",
    "blogging"
  ],
  "author": "Armoghan-ul-Mohmin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armoghan-Blogs/Armoghan-Blogs.git"
  },
  "homepage": "https://github.com/Armoghan-Blogs/Armoghan-Blogs#readme",
  "bugs": {
    "url": "https://github.com/Armoghan-Blogs/Armoghan-Blogs/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "eslint": "^9.8.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "markdownlint": "^0.34.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.1"
  }
}
