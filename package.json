{
  "name": "armoghan-blogs",
  "version": "1.0.0",
  "description": "My Personal Blogs Website built using Hugo and Decap-CMS",
  "main": ".commitlintrc.js",
  "scripts": {
    "stylelint": "stylelint '**/*.css'",
    "stylelint:fix": "stylelint '**/*.css' --fix",
    "format": "npm run prettier",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "eslint:fix": "eslint . --fix",
    "htmlhint": "htmlhint '**/*.html'",
    "markdownlint": "markdownlint '**/*.md'",
    "lint": "npm run eslint:fix && npm run stylelint:fix && npm run htmlhint && npm run markdownlint",
    "clean": "rm -rf public",
    "audit": "npm audit",
    "audit:fix": "npm audit --fix",
    "update": "npm update",
    "depcheck": "npx depcheck",
    "cache-clean": "npm cache clean --force",
    "rebuild-node-modules": "rm -rf node_modules && npm install",
    "clean-logs": "rm -f hugo.build.lock && find . -name '*.log' -type f -delete",
    "prepare": "husky install"
  },
  "keywords": [
    "hugo",
    "hugo-theme",
    "tailwind",
    "dark-mode",
    "static-site",
    "content-management",
    "decap-cms",
    "decap-cms-app",
    "netlify",
    "blogs",
    "web-development",
    "responsive-design",
    "frontend",
    "site-generator",
    "modern-web",
    "opensource",
    "website",
    "personal-blog",
    "armoghan-blogs",
    "armoghan",
    "blogging"
  ],
  "author": "Armoghan-ul-Mohmin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armoghan-Blogs/Armoghan-Blogs.git"
  },
  "homepage": "https://github.com/Armoghan-Blogs/Armoghan-Blogs#readme",
  "bugs": {
    "url": "https://github.com/Armoghan-Blogs/Armoghan-Blogs/issues"
  },
    "browserslist": [
    "last 1 version",
    ">= 1%",
    "not dead"
  ],
    "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "markdownlint": "^0.34.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.1"
  }
}
